# PostgreSQL database connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/spplabs?schema=public"

# Secret key used for JWT signing and verification (should be a secure, random string)
JWT_SECRET="generate_a_secure_random_key_of_at_least_32_characters_here"

# The API key generated during database seeding (or by admin) for spplabs.es
API_KEY="spp_live_replace_with_seeded_spplabs_es_key_here"

# The API URL where requests are sent (pointing to api.spplabs.es or localhost in development)
API_URL="http://localhost:3000"

# ClickHouse Connection Configurations

# 1. API Event Ingestion User (Write-Only)
CLICKHOUSE_API_HOST="http://localhost:8123"
CLICKHOUSE_API_USER="analytics_api"
CLICKHOUSE_API_PASSWORD="write_password_here"
CLICKHOUSE_API_DATABASE="analytics"

# 2. Dashboard Query User (Read-Only)
CLICKHOUSE_DASHBOARD_HOST="http://localhost:8123"
CLICKHOUSE_DASHBOARD_USER="analytics_dashboard"
CLICKHOUSE_DASHBOARD_PASSWORD="read_password_here"
CLICKHOUSE_DASHBOARD_DATABASE="analytics"

# 3. Database Administrator User (For Schema Creation/Admin CLI tools)
# CLICKHOUSE_ADMIN_USER="spplabs_admin"
# CLICKHOUSE_ADMIN_PASSWORD="admin_password_here"
